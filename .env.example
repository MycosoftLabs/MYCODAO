# Copy to `.env.local` (dev) or `.env.production` (VM). Never commit real secrets.

# Cloudflare Tunnel (optional). Token from Zero Trust → Networks → Tunnels → your tunnel → token.
# Used by `docker compose --profile tunnel`. See docs/PULSE_CLOUDFLARE_TUNNEL_SETUP_APR14_2026.md
CLOUDFLARE_TUNNEL_TOKEN=



# Empty = app at domain root (e.g. https://blocks.mycodao.com/). Set only if serving under a subpath.

# Must match `next.config.mjs` / build-time embedding (e.g. `/mycodao.financial` for legacy subpath deploys).

NEXT_PUBLIC_BASE_PATH=



# Client: enable SSE ticker stream (`/api/pulse/stream`). Set `1` or `true` to connect from Pulse UI.

NEXT_PUBLIC_PULSE_SSE=



# Market data (server-only). Required for best OHLC + quotes; see https://finnhub.io

FINNHUB_API_KEY=

# Finnhub webhook verification (dashboard → Webhooks). Register URL:
# https://blocks.mycodao.com/api/pulse/finnhub-webhook?secret=<this value>
# See docs/FINNHUB_PULSE_WEBHOOK_JUN05_2026.md

FINNHUB_WEBHOOK_SECRET=



# Optional: MINDEX OHLC when `/api/ohlc` is implemented server-side

# On the dedicated MycoDAO guest (Proxmox 192.168.0.90), point at LAN APIs — no changes to those VMs:

# MINDEX_API_URL=http://192.168.0.189:8000

# MAS_API_URL=http://192.168.0.188:8001

MINDEX_API_URL=

MINDEX_INTERNAL_TOKEN=



MAS_API_URL=



# Optional: NatureOS — used by `npm run check:backends`

NATUREOS_API_URL=



# MYCO token price from DexScreener

MYCO_SOLANA_MINT=

# Canonical MYCO/SOL pair on DexScreener (not the mint address)

MYCO_DEX_PAIR=FgCQoL7tcC1nkNazV5onEgWbm9UJ9nbzqo9rZCYm6Yi4

NEXT_PUBLIC_MYCO_DEX_PAIR=FgCQoL7tcC1nkNazV5onEgWbm9UJ9nbzqo9rZCYm6Yi4

NEXT_PUBLIC_MYCO_SOLANA_MINT=EzYEwn4R5tNkNGw4K2a5a58MJFQESdf1r4UJrV7cpUF3



# News (server-only). GNews is preferred when set; some adapters accept `NEWS_API_KEY` as alias.

GNEWS_API_KEY=

NEWS_API_KEY=



# Podcasts: comma-separated RSS URLs for `/api/podcasts`.
# When unset, defaults to official MycoPOD: https://media.rss.com/mycopod/feed.xml
# Append extra feeds comma-separated if needed (max 5).

PODCAST_RSS_URLS=



# Learn (`/pulse/learn`): optional HTTPS JSON array of LearnModule (same schema as `data/learn-modules.json`)

LEARN_MODULES_URL=



# Dev only: when unset remote/file missing or invalid, serve minimal fallback lessons (never enable in production)

LEARN_DEV_FALLBACK=



# --- Pulse Podcast studio (`/pulse/podcasts`) — live, stream deck, chat ---

# Default live iframe (YouTube Live embed, Cloudflare Stream, etc.)

# NEXT_PUBLIC_PULSE_PODCAST_LIVE_EMBED_URL=https://www.youtube.com/embed/LIVE_VIDEO_ID

# Label next to LIVE badge

# NEXT_PUBLIC_PULSE_PODCAST_LIVE_LABEL=MycoDAO Live

# Stream deck: JSON array of { "id", "label", "embedUrl" } — https embed URLs only; switches live iframe

# NEXT_PUBLIC_PULSE_STREAMDECK_JSON=[{"id":"main","label":"Program","embedUrl":"https://www.youtube.com/embed/..."}]

# Chat persists to `data/podcast-chat.json` (single-instance; gitignored)




# Calendar: optional JSON URL override (else Finnhub economic calendar when `FINNHUB_API_KEY` is set)

CALENDAR_JSON_URL=



# Pulse behavior (see lib/server/pulse-env.ts)

PULSE_TRADE_FAST_PATH=1



# --- Trading terminal (DEX/CEX via broker service; see lib/server/trading-env.ts) ---

# Base URL of your execution adapter (MAS, CCXT, Jupiter, etc.). Must implement:

#   POST /v1/orders  GET /v1/orders  GET /v1/positions  optional POST /v1/quote

TRADING_BROKER_BASE_URL=

# Outbound auth to the broker (optional)

TRADING_BROKER_TOKEN=



# Agents & scripts send this header to Pulse: Authorization: Bearer ... or X-Pulse-Trading-Key

PULSE_TRADING_API_KEY=



# LAN/VPN only: allow browser POST from same origin without the key (use with care)

PULSE_TRUST_SAME_ORIGIN_TRADING=



# Optional smoke script override (default: http://localhost:3004 + NEXT_PUBLIC_BASE_PATH)

# PULSE_SMOKE_BASE=http://localhost:3004



# --- Pulse → MAS task proxy (`POST /api/pulse/mas-task`) — server only; never expose secret to browser

# Shared secret: client of the route must send header `x-pulse-internal-key: <value>`

PULSE_MAS_PROXY_SECRET=



# Dev/LAN only: allow proxy without key (never set in public production)

PULSE_ALLOW_OPEN_MAS_PROXY=



# Producer Google OAuth return URL (optional — auto-detected from Host on local/LAN and blocks.mycodao.com).
# Only set to override; add matching URLs in Supabase → Auth → Redirect URLs, e.g.:
#   http://localhost:3004/blocks/*
#   http://192.168.0.x:3004/blocks/*
#   https://blocks.mycodao.com/blocks/*
# PRODUCER_OAUTH_REDIRECT_URL=

# --- Supabase (producer magic-link + optional edge logs) ---

# Required on VM `.env.production` for Blocks producer sign-in (pulse loads at runtime via /api/pulse/public-config).

NEXT_PUBLIC_SUPABASE_URL=

NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Aliases accepted by server helpers (optional if NEXT_PUBLIC_* set)

SUPABASE_URL=

SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=



# --- Pulse News terminal (`/pulse/news`) — client NEXT_PUBLIC_* (read at Vite build) ---

# YouTube Live viewer embed (pick one). Rebuild after change: npm run build:pulse

# Full embed URL, watch URL, or bare video ID:

# NEXT_PUBLIC_PULSE_NEWS_VIDEO_EMBED_URL=https://www.youtube.com/embed/VIDEO_ID

# Or channel ID (auto live_stream embed when you are live on YouTube):

# NEXT_PUBLIC_PULSE_NEWS_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx

# Or current live / VOD video ID only:

# NEXT_PUBLIC_PULSE_NEWS_YOUTUBE_VIDEO_ID=xxxxxxxxxxx

# OBS ingest (public server URL — stream key from YouTube Studio only, never commit):

# rtmp://a.rtmp.youtube.com/live2

# Optional label next to LIVE badge

# NEXT_PUBLIC_PULSE_NEWS_STREAM_LABEL=MycoDAO News

# --- News program schedule (server — no pulse rebuild to swap live) ---

# Instant "go live" override (wins over data/news-channel-schedule.json):

# NEWS_CHANNEL_LIVE_OVERRIDE_URL=https://www.youtube.com/watch?v=VIDEO_ID

# NEWS_CHANNEL_LIVE_OVERRIDE_LABEL=Live Desk

# Optional custom schedule file (default: data/news-channel-schedule.json)

# NEWS_CHANNEL_SCHEDULE_PATH=

# --- BLOCKS Scheduler (Streamlabs + Google Calendar) — server only ---

# Streamlabs Desktop on LAN: Settings → Remote Control → token; API default port 59650
# STREAMLABS_REMOTE_API_URL=http://192.168.0.241:59650/api
# STREAMLABS_REMOTE_TOKEN=  (prefer .credentials.local; never commit)

# Google Calendar import (public iCal URL or calendar ID / email)
# GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics
# GOOGLE_CALENDAR_ID=

# LAN dev base for calendar subscribe feed URLs in API responses
# BLOCKS_PUBLIC_BASE_URL=http://192.168.0.241:3004
# NEXT_PUBLIC_BLOCKS_BASE_URL=http://192.168.0.241:3004

# n8n hourly import auth (falls back to NEWS_PRODUCER_API_KEY)
# BLOCKS_SCHEDULER_CRON_SECRET=
# BLOCKS_CALENDAR_FEED_TOKEN=
# BLOCKS_CALENDAR_AUTO_IMPORT=0

# --- News producer dashboard (`/blocks/#producer`) — server only ---

# Required in production for PATCH /api/news/producer (talent tags, bumpers, cut-ins)

# NEWS_PRODUCER_API_KEY=

# Optional paths (default: data/news-producer-state.json, data/news-producer-presets.json)

# NEWS_PRODUCER_STATE_PATH=

# NEWS_PRODUCER_PRESETS_PATH=

# --- BLOCKS NAS producer media (commercials, shows, live-streams, graphics, bumpers) ---

# Same UniFi NAS as MINDEX library — different folder under MYCODAO/BLOCKS

# NAS_HOST=192.168.0.105

# NAS_SMB_USER=mycosoft

# NAS_SMB_PASSWORD=  (never commit — .credentials.local)

# Share is //192.168.0.105/MYCODAO (not under mycosoft.com). Subfolder: BLOCKS/

# BLOCKS_NAS_SHARE=//192.168.0.105/MYCODAO

# BLOCKS_NAS_CIFS_URL=//192.168.0.105/MYCODAO/BLOCKS

# Linux VM: mount share then symlink — scripts/setup_blocks_nas_mount.sh

# BLOCKS_NAS_ROOT=/mnt/nas/mycodao/BLOCKS

# Windows dev UNC: BLOCKS_NAS_ROOT=\\192.168.0.105\MYCODAO\BLOCKS

# Web: https://192.168.0.105/drive/shared-drives/MYCODAO/BLOCKS

# Comma-separated symbols for the top tape (must exist in `/api/tickers` feed)

# NEXT_PUBLIC_PULSE_NEWS_TAPE_SYMBOLS=BTC,ETH,SPY,QQQ,MYCO,NVDA

# Sponsorship images (full URLs). Secondary is optional banner below primary.

# NEXT_PUBLIC_PULSE_NEWS_AD_IMAGE_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_SECONDARY_IMAGE_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_CLICK_URL=

# NEXT_PUBLIC_PULSE_NEWS_AD_TITLE=



# Realms V2 DAO hub (Pulse). Public explore API works without a key.

# REALMS_V2_API_URL=https://v2.realms.today/api/v1

# REALMS_DAO_CACHE_TTL_MS=1800000

# SOLANA_RPC_URL=  # server treasury SPL enrichment (optional; public RPC default)

# --- Phantom Connect (Pulse Organizations / DAO tab) — client VITE_* in myco-pulse ---

# VITE_PHANTOM_APP_ID=0b78c207-6c6c-4ab7-8350-8f02552f3298

# VITE_PHANTOM_REDIRECT_URL=https://pulse.mycodao.com

# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# VITE_PULSE_API_ORIGIN=http://127.0.0.1:3004

# ResearchHub Django API (defaults to public https://api.researchhub.com when unset)
# RESEARCHHUB_API_BASE=https://api.researchhub.com


