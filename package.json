{
  "name": "mycodao",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3004 -H 0.0.0.0",
    "dev:mobile": "npm run build:pulse && next dev -p 3004 -H 0.0.0.0",
    "dev:fresh": "npm run clean && next dev -p 3004",
    "dev:pulse": "npm run build:pulse && next dev -p 3004",
    "build:pulse": "cd myco-pulse && npm run build",
    "build": "npm run build:pulse && next build",
    "start": "next start -p 3004",
    "clean": "rimraf .next node_modules/.cache",
    "clean:build": "npm run clean && npm run build",
    "lint": "next lint",
    "check:backends": "node scripts/check-pulse-backends.mjs",
    "test:pulse-smoke": "node scripts/pulse-smoke-local.mjs",
    "test:producer-side-panel": "node scripts/test-producer-side-panel.mjs",
    "test:producer-patch": "npx --yes tsx scripts/test-producer-patch-direct.ts",
    "test:scheduler-integrations": "node scripts/test-scheduler-integrations-local.mjs",
    "test:pulse-smoke:prod": "node scripts/pulse-smoke-local.mjs https://blocks.mycodao.com",
    "test:blocks-smoke:prod": "node scripts/pulse-smoke-local.mjs https://blocks.mycodao.com",
    "docs:pdf": "node scripts/generate-report-pdf.js",
    "figma:export": "node scripts/export-figma-assets.mjs",
    "mount:nas": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/mount-blocks-nas.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "lightweight-charts": "^4.2.1",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rss-parser": "^3.13.0",
    "sockjs-client": "1.6.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "25.3.4",
    "@types/react": "19.2.14",
    "@types/sockjs-client": "1.5.4",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "md-to-pdf": "^5.2.5",
    "postcss": "^8.4.38",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.4"
  }
}
