# Supabase Configuration (producer sign-in + edge logs)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Next root .env.local may also set NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
# Server producer allowlist (optional override):
# NEWS_PRODUCER_ALLOWED_EMAILS=morgan@mycosoft.org,morgan@mycodao.com,abelardo@mycosoft.org,abelardo@mycodao.com

# Gemini (neural reports, news synthesis) — also readable as GEMINI_API_KEY at build time
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=
